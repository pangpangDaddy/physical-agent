{
  "name": "gru-ai",
  "private": false,
  "version": "0.3.1",
  "type": "module",
  "bin": {
    "gru-ai": "dist-cli/index.js"
  },
  "files": [
    "dist/",
    "dist-cli/",
    "dist-server/",
    "cli/templates/",
    "cli/resolve-pkg-root.sh",
    ".claude/hooks/",
    ".claude/skills/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "predev": "lsof -ti :4444 | xargs kill -9 2>/dev/null; pkill -f 'vite.*gruai' 2>/dev/null; echo 'Cleaned stale dev processes'",
    "dev": "concurrently --kill-others-on-fail \"tsx watch server/index.ts\" \"vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build:cli": "tsc -p cli/tsconfig.json",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "build": "npm run build:cli && npm run build:client && npm run build:server",
    "prepublishOnly": "npm run build",
    "start": "node dist-server/server/index.js",
    "setup": "./install.sh",
    "pack": "./pack.sh",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-virtual": "^3.13.18",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "katex": "^0.16.47",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.19.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.6"
  }
}
